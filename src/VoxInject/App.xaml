<Application x:Class="VoxInject.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:tb="http://www.hardcodet.net/taskbar">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemeResources RequestedTheme="Dark"/>
                <ui:XamlControlsResources/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Systray icon declared in XAML — required by H.NotifyIcon for proper Win32 HICON handling -->
            <tb:TaskbarIcon x:Key="TrayIcon"
                            IconSource="pack://application:,,,/Assets/app.ico"
                            ToolTipText="VoxInject"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
