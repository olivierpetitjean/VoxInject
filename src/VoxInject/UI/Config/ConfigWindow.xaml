<ui:FluentWindow x:Class="VoxInject.UI.Config.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="VoxInject — Settings"
        Width="560" Height="540"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- title bar  -->
            <RowDefinition Height="*"/>     <!-- tab area   -->
            <RowDefinition Height="Auto"/>  <!-- footer bar -->
        </Grid.RowDefinitions>

        <!-- ── Title bar ──────────────────────────────────────────────────── -->
        <ui:TitleBar Grid.Row="0"
                     Title="VoxInject — Settings"
                     ShowMaximize="False"
                     ShowMinimize="False"/>

        <!-- ── Tabs ────────────────────────────────────────────────────────── -->
        <TabControl Grid.Row="1" Margin="20,4,0,0">

            <!-- ┌─ API ────────────────────────────────────────────────────┐ -->
            <TabItem Header="API">
                <StackPanel Margin="4,20">
                    <TextBlock Text="ASSEMBLYAI"
                               FontSize="11" FontWeight="SemiBold" Opacity="0.6"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="Clé API" FontSize="12" Opacity="0.7"
                               Margin="0,0,0,4"/>
                    <ui:PasswordBox x:Name="ApiKeyBox"
                                    PlaceholderText="sk-••••••••••••••••"/>
                </StackPanel>
            </TabItem>

            <!-- ┌─ Profil ─────────────────────────────────────────────────┐ -->
            <TabItem Header="Profil">
                <StackPanel Margin="4,20">
                    <TextBlock Text="PROFIL"
                               FontSize="11" FontWeight="SemiBold" Opacity="0.6"
                               Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="ProfileCombo" Grid.Column="0"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="ProfileCombo_SelectionChanged"/>
                        <ui:Button Grid.Column="1" Content="+" Width="36"
                                   Margin="6,0,0,0"
                                   Click="AddProfile_Click" ToolTip="Nouveau profil"/>
                        <ui:Button Grid.Column="2" Content="✕" Width="36"
                                   Margin="6,0,0,0"
                                   Click="DeleteProfile_Click" ToolTip="Supprimer"/>
                    </Grid>

                    <TextBlock Text="Langue (ex : fr, en, de)"
                               FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                    <TextBox x:Name="LanguageBox" Margin="0,0,0,16"/>

                    <TextBlock Text="Vocabulaire spécifique (mots séparés par des virgules)"
                               FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                    <TextBox x:Name="VocabBoostBox" Margin="0,0,0,16"/>

                    <CheckBox x:Name="AutoPunctCheck" Content="Ponctuation automatique"/>
                </StackPanel>
            </TabItem>

            <!-- ┌─ Saisie ─────────────────────────────────────────────────┐ -->
            <TabItem Header="Saisie">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="4,20">

                    <!-- Microphone -->
                    <TextBlock Text="MICROPHONE"
                               FontSize="11" FontWeight="SemiBold" Opacity="0.6"
                               Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="MicCombo" Grid.Column="0"
                                  HorizontalAlignment="Stretch"/>
                        <ui:Button Grid.Column="1" Content="Test"
                                   Margin="8,0,0,0" Click="TestMic_Click"/>
                    </Grid>

                    <!-- Mode -->
                    <TextBlock Text="MODE"
                               FontSize="11" FontWeight="SemiBold" Opacity="0.6"
                               Margin="0,0,0,10"/>
                    <ComboBox x:Name="RecordModeCombo"
                              HorizontalAlignment="Stretch" Margin="0,0,0,18">
                        <ComboBoxItem Content="Toggle"       Tag="Toggle"/>
                        <ComboBoxItem Content="Push to talk" Tag="PushToTalk"/>
                    </ComboBox>

                    <!-- Auto Enter -->
                    <ui:Card Margin="0,0,0,18">
                        <StackPanel>
                            <CheckBox x:Name="AutoEnterCheck"
                                      Content="Appuyer automatiquement sur Entrée après le silence"
                                      Margin="0,0,0,14"
                                      Checked="AutoEnterCheck_Changed"
                                      Unchecked="AutoEnterCheck_Changed"/>
                            <StackPanel x:Name="SilencePanel" IsEnabled="False">
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="96"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Délai de silence (ms)"
                                               FontSize="12" Opacity="0.7"
                                               VerticalAlignment="Center"/>
                                    <TextBox x:Name="SilenceBox" Grid.Column="1"
                                             Text="1500"
                                             HorizontalContentAlignment="Right"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Touche à presser"
                                               FontSize="12" Opacity="0.7"
                                               VerticalAlignment="Center"/>
                                    <ComboBox x:Name="EnterKeyCombo" Grid.Column="1"
                                              MinWidth="136">
                                        <ComboBoxItem Content="Entrée"       Tag="Enter"/>
                                        <ComboBoxItem Content="Shift+Entrée" Tag="ShiftEnter"/>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </ui:Card>

                    <!-- Hotkey -->
                    <TextBlock Text="RACCOURCI CLAVIER"
                               FontSize="11" FontWeight="SemiBold" Opacity="0.6"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="Cliquez dans le champ puis appuyez sur votre raccourci"
                               FontSize="12" Opacity="0.7" Margin="0,0,0,6"/>
                    <TextBox x:Name="HotkeyBox" IsReadOnly="True" Cursor="Hand"
                             Margin="0,0,0,20"
                             PreviewKeyDown="HotkeyBox_PreviewKeyDown"
                             GotFocus="HotkeyBox_GotFocus"
                             LostFocus="HotkeyBox_LostFocus"/>
                </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ┌─ Overlay ────────────────────────────────────────────────┐ -->
            <TabItem Header="Overlay">
                <StackPanel Margin="4,20">
                    <TextBlock Text="POSITION"
                               FontSize="11" FontWeight="SemiBold" Opacity="0.6"
                               Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Coin" FontSize="12" Opacity="0.7"
                                       Margin="0,0,0,4"/>
                            <ComboBox x:Name="CornerCombo" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="Haut gauche"  Tag="TopLeft"/>
                                <ComboBoxItem Content="Haut droite"  Tag="TopRight"/>
                                <ComboBoxItem Content="Bas gauche"   Tag="BottomLeft"/>
                                <ComboBoxItem Content="Bas droite"   Tag="BottomRight"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="Écran" FontSize="12" Opacity="0.7"
                                       Margin="0,0,0,4"/>
                            <ComboBox x:Name="ScreenCombo" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="Écran actif"     Tag="ActiveScreen"/>
                                <ComboBoxItem Content="Écran principal" Tag="PrimaryScreen"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="APPARENCE"
                               FontSize="11" FontWeight="SemiBold" Opacity="0.6"
                               Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Opacité" FontSize="12" Opacity="0.7"
                                       Margin="0,0,0,8"/>
                            <Slider x:Name="OpacitySlider" Minimum="0.3" Maximum="1.0"
                                    SmallChange="0.05" TickFrequency="0.05"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="Taille (px)" FontSize="12" Opacity="0.7"
                                       Margin="0,0,0,8"/>
                            <Slider x:Name="SizeSlider" Minimum="40" Maximum="120"
                                    SmallChange="4" TickFrequency="4"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </TabItem>

            <!-- ┌─ Système ────────────────────────────────────────────────┐ -->
            <TabItem Header="Système">
                <StackPanel Margin="4,20">
                    <TextBlock Text="SON"
                               FontSize="11" FontWeight="SemiBold" Opacity="0.6"
                               Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="ToneCheck" Grid.Column="0"
                                  Content="Son d'activation"
                                  VerticalAlignment="Center"/>
                        <Slider x:Name="ToneVolumeSlider" Grid.Column="1"
                                Minimum="0" Maximum="1" Margin="16,0,0,0"
                                SmallChange="0.05" VerticalAlignment="Center"/>
                    </Grid>

                    <TextBlock Text="DÉMARRAGE"
                               FontSize="11" FontWeight="SemiBold" Opacity="0.6"
                               Margin="0,0,0,10"/>
                    <CheckBox x:Name="AutoStartCheck" Content="Lancer avec Windows"/>
                </StackPanel>
            </TabItem>

        </TabControl>

        <!-- ── Footer ──────────────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                BorderThickness="0,1,0,0"
                BorderBrush="{ui:ThemeResource ControlElevationBorderBrush}"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ui:Button Grid.Column="1" Content="Annuler"
                           Margin="0,0,8,0" Click="Cancel_Click"/>
                <ui:Button Grid.Column="2" Content="Enregistrer"
                           Appearance="Primary" Click="Save_Click"/>
            </Grid>
        </Border>

    </Grid>
</ui:FluentWindow>
