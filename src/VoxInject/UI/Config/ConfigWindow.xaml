<Window x:Class="VoxInject.UI.Config.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="VoxInject — Settings"
        Width="520" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16,12">

            <!-- AssemblyAI -->
            <ui:SimpleStackPanel Spacing="4" Margin="0,0,0,16">
                <TextBlock Text="AssemblyAI" Style="{StaticResource SubtitleTextBlockStyle}"/>
                <TextBlock Text="API Key" Style="{StaticResource BodyTextBlockStyle}" Opacity="0.6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <PasswordBox x:Name="ApiKeyBox" Grid.Column="0" PasswordChar="●"/>
                    <ToggleButton x:Name="RevealToggle" Grid.Column="1"
                                  Width="36" Margin="6,0,0,0"
                                  Content="&#128065;"
                                  ToolTip="Show / hide key"
                                  Checked="RevealToggle_Checked"
                                  Unchecked="RevealToggle_Unchecked"/>
                    <TextBox x:Name="ApiKeyPlain" Grid.Column="0" Visibility="Collapsed"/>
                </Grid>
            </ui:SimpleStackPanel>

            <Separator Margin="0,0,0,16"/>

            <!-- Profile -->
            <ui:SimpleStackPanel Spacing="4" Margin="0,0,0,16">
                <TextBlock Text="Profile" Style="{StaticResource SubtitleTextBlockStyle}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="ProfileCombo" Grid.Column="0"
                              HorizontalAlignment="Stretch"
                              SelectionChanged="ProfileCombo_SelectionChanged"/>
                    <Button Grid.Column="1" Content="+" Width="36" Margin="6,0,0,0"
                            Click="AddProfile_Click" ToolTip="New profile"/>
                    <Button Grid.Column="2" Content="✕" Width="36" Margin="6,0,0,0"
                            Click="DeleteProfile_Click" ToolTip="Delete profile"/>
                </Grid>
                <TextBlock Text="Language (e.g. fr, en, de)" Opacity="0.6" FontSize="12"/>
                <TextBox x:Name="LanguageBox"/>
                <TextBlock Text="Vocabulary boost (comma-separated words)" Opacity="0.6" FontSize="12"/>
                <TextBox x:Name="VocabBoostBox"/>
                <CheckBox x:Name="AutoPunctCheck" Content="Auto punctuation"/>
            </ui:SimpleStackPanel>

            <Separator Margin="0,0,0,16"/>

            <!-- Recording -->
            <ui:SimpleStackPanel Spacing="4" Margin="0,0,0,16">
                <TextBlock Text="Recording" Style="{StaticResource SubtitleTextBlockStyle}"/>
                <TextBlock Text="Microphone" Opacity="0.6" FontSize="12"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="MicCombo" Grid.Column="0" HorizontalAlignment="Stretch"/>
                    <Button Grid.Column="1" Content="Test" Margin="6,0,0,0"
                            Click="TestMic_Click"/>
                </Grid>
                <TextBlock Text="Mode" Opacity="0.6" FontSize="12"/>
                <ComboBox x:Name="RecordModeCombo" HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="Toggle"       Tag="Toggle"/>
                    <ComboBoxItem Content="Push to talk" Tag="PushToTalk"/>
                </ComboBox>
                <CheckBox x:Name="AutoEnterCheck"
                          Content="Auto press Enter on silence"
                          Checked="AutoEnterCheck_Changed"
                          Unchecked="AutoEnterCheck_Changed"/>
                <Grid x:Name="SilencePanel" IsEnabled="False">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Silence timeout (ms)"
                               VerticalAlignment="Center" Opacity="0.6" FontSize="12"/>
                    <TextBox x:Name="SilenceBox" Grid.Column="1" Text="1500"
                             HorizontalContentAlignment="Right"/>
                </Grid>
            </ui:SimpleStackPanel>

            <Separator Margin="0,0,0,16"/>

            <!-- Hotkey -->
            <ui:SimpleStackPanel Spacing="4" Margin="0,0,0,16">
                <TextBlock Text="Hotkey" Style="{StaticResource SubtitleTextBlockStyle}"/>
                <TextBlock Text="Click field then press your shortcut" Opacity="0.6" FontSize="12"/>
                <TextBox x:Name="HotkeyBox" IsReadOnly="True"
                         PreviewKeyDown="HotkeyBox_PreviewKeyDown"
                         GotFocus="HotkeyBox_GotFocus"
                         LostFocus="HotkeyBox_LostFocus"
                         Cursor="Hand"/>
            </ui:SimpleStackPanel>

            <Separator Margin="0,0,0,16"/>

            <!-- Overlay -->
            <ui:SimpleStackPanel Spacing="4" Margin="0,0,0,16">
                <TextBlock Text="Overlay" Style="{StaticResource SubtitleTextBlockStyle}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ui:SimpleStackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                        <TextBlock Text="Corner" Opacity="0.6" FontSize="12"/>
                        <ComboBox x:Name="CornerCombo" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="Top Left"     Tag="TopLeft"/>
                            <ComboBoxItem Content="Top Right"    Tag="TopRight"/>
                            <ComboBoxItem Content="Bottom Left"  Tag="BottomLeft"/>
                            <ComboBoxItem Content="Bottom Right" Tag="BottomRight"/>
                        </ComboBox>
                        <TextBlock Text="Screen" Opacity="0.6" FontSize="12"/>
                        <ComboBox x:Name="ScreenCombo" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="Active screen"  Tag="ActiveScreen"/>
                            <ComboBoxItem Content="Primary screen" Tag="PrimaryScreen"/>
                        </ComboBox>
                    </ui:SimpleStackPanel>
                    <ui:SimpleStackPanel Grid.Column="1" Spacing="8">
                        <TextBlock Text="Opacity" Opacity="0.6" FontSize="12"/>
                        <Slider x:Name="OpacitySlider" Minimum="0.3" Maximum="1.0"
                                SmallChange="0.05" TickFrequency="0.05"/>
                        <TextBlock Text="Size (px)" Opacity="0.6" FontSize="12"/>
                        <Slider x:Name="SizeSlider" Minimum="40" Maximum="120"
                                SmallChange="4" TickFrequency="4"/>
                    </ui:SimpleStackPanel>
                </Grid>
            </ui:SimpleStackPanel>

            <Separator Margin="0,0,0,16"/>

            <!-- Tone -->
            <ui:SimpleStackPanel Spacing="8" Margin="0,0,0,16">
                <TextBlock Text="Tone" Style="{StaticResource SubtitleTextBlockStyle}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox x:Name="ToneCheck" Grid.Column="0"
                              Content="Enable activation tone"
                              VerticalAlignment="Center"/>
                    <Slider x:Name="ToneVolumeSlider" Grid.Column="1"
                            Minimum="0" Maximum="1" Margin="12,0,0,0"
                            SmallChange="0.05"/>
                </Grid>
            </ui:SimpleStackPanel>

            <Separator Margin="0,0,0,16"/>

            <!-- System -->
            <ui:SimpleStackPanel Spacing="4" Margin="0,0,0,16">
                <TextBlock Text="System" Style="{StaticResource SubtitleTextBlockStyle}"/>
                <CheckBox x:Name="AutoStartCheck" Content="Start with Windows"/>
            </ui:SimpleStackPanel>

            <!-- Buttons -->
            <Grid Margin="0,8,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="1" Content="Cancel"
                        Margin="0,0,8,0" Click="Cancel_Click"/>
                <Button Grid.Column="2" Content="Save"
                        Click="Save_Click"
                        Style="{StaticResource AccentButtonStyle}"/>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Window>
