<Window x:Class="VoxInject.UI.Overlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="64" Height="64"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- Pulse animation triggered by audio level via code-behind -->
        <Storyboard x:Key="PulseIn" AutoReverse="False">
            <DoubleAnimation Storyboard.TargetName="PulseRing"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="0.5" Duration="0:0:0.15"/>
        </Storyboard>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetName="Root"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.15"/>
        </Storyboard>
        <Storyboard x:Key="FadeOut">
            <DoubleAnimation Storyboard.TargetName="Root"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.2"/>
        </Storyboard>
    </Window.Resources>

    <!-- Root grid carries the fade-in/out opacity -->
    <Grid x:Name="Root" Opacity="0">

        <!-- Pulse ring: scales with audio level -->
        <Ellipse x:Name="PulseRing"
                 Opacity="0"
                 HorizontalAlignment="Stretch"
                 VerticalAlignment="Stretch"
                 Margin="-6"
                 Fill="Transparent"
                 Stroke="#AA6A3DE8"
                 StrokeThickness="3">
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="PulseScale"
                                CenterX="38" CenterY="38"
                                ScaleX="1" ScaleY="1"/>
            </Ellipse.RenderTransform>
        </Ellipse>

        <!-- Main circle background -->
        <Ellipse x:Name="MainCircle"
                 HorizontalAlignment="Stretch"
                 VerticalAlignment="Stretch"
                 Margin="4">
            <Ellipse.Fill>
                <SolidColorBrush Color="#E6141414"/>
            </Ellipse.Fill>
            <Ellipse.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="2"
                                  Color="#80000000" Opacity="0.6"/>
            </Ellipse.Effect>
        </Ellipse>

        <!-- Mic icon (vector path — standard microphone shape) -->
        <Viewbox Margin="18">
            <Canvas Width="24" Height="24">
                <!-- Mic body -->
                <Path Fill="#E0E0E0">
                    <Path.Data>
                        M12,14 C13.66,14 15,12.66 15,11 L15,5 C15,3.34 13.66,2 12,2
                        C10.34,2 9,3.34 9,5 L9,11 C9,12.66 10.34,14 12,14 Z
                    </Path.Data>
                </Path>
                <!-- Mic stand arc -->
                <Path Fill="#E0E0E0">
                    <Path.Data>
                        M17,11 C17,13.76 14.76,16 12,16 C9.24,16 7,13.76 7,11
                        L5,11 C5,14.53 7.61,17.43 11,17.93 L11,20 L9,20 L9,22
                        L15,22 L15,20 L13,20 L13,17.93 C16.39,17.43 19,14.53 19,11 Z
                    </Path.Data>
                </Path>
            </Canvas>
        </Viewbox>

        <!-- Status dot (bottom-right): shows state color -->
        <Ellipse x:Name="StatusDot"
                 Width="10" Height="10"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,6,6"
                 Fill="#44CC44"/>

    </Grid>
</Window>
